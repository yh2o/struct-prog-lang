// Arithmetic and basic expressions
print 3 + 4 * 5

// Variables and assignment
x = 10
y = 20
print x + y

// Comparisons
print 3 == 3
print 3 != 5
print 10 < 20
print 5 <= 5
print 15 > 10
print 10 >= 10

// Boolean literals
print true
print false

// Logical AND (both syntaxes)
print true and true
print true && false

// Logical OR (both syntaxes)
print false or true
print false || false

// Logical NOT (both syntaxes)
print not true
print !false

// Complex boolean expressions
a = 5
b = 10
print a < b and b > 0
print a == 5 or b == 5
print not (a > b)

// Operator precedence: comparisons bind tighter than logical ops
print 3 < 5 and 5 < 10

// Unary negation
print -5
print --10
print -(3 + 4)

// All operators together
print 2 + 3 * 4 > 10 and not false

